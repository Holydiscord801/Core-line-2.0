SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string, used by scripts/run-migration.ts for DDL
# that PostgREST cannot execute. Get it from the Supabase Dashboard:
#   Project Settings -> Database -> Connection string -> URI
# Prefer the "Session" pooler URL (port 5432) on the
# aws-*.pooler.supabase.com host; the legacy db.<ref>.supabase.co direct
# endpoint is no longer reachable on newer projects.
# Format: postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-us-east-2.pooler.supabase.com:5432/postgres

PORT=3001
JWT_SECRET=your-jwt-secret-here
